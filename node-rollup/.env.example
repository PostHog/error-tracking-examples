# PostHog error tracking — credentials for the SDK (runtime) and source map upload (build time).
# Copy to .env and fill in. The values below are the PostHog local-dev defaults.

POSTHOG_HOST=http://localhost:8010

# Public project API key (project 1) — used by posthog-node at runtime to send events.
# This value is per-database. Fetch the current one for a local instance with:
#   curl -s http://localhost:8010/api/projects/1/ \
#     -H "Authorization: Bearer $POSTHOG_API_KEY" | jq -r .api_token
POSTHOG_KEY=phc_kD64gg5WuNKZnrtXAxVrMiDdL49jeTfCxTsnvzM2DugB

# Personal API key with error-tracking write scope — used to upload source maps at build time.
# The value below is the deterministic PostHog local-dev key seeded by
# `python manage.py setup_local_api_key` (see ee/settings.py DEV_API_KEY).
POSTHOG_API_KEY=phx_dev_local_test_api_key_1234567890abcdef
POSTHOG_PROJECT_ID=1
